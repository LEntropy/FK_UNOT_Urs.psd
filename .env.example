# Root-level compose overrides. Copy to .env before `docker compose up` if
# you need any of these; the stack runs fine with none of them set.

# Optional. Mounted into detection-svc for reverse-image search (Google
# Cloud Vision Web Detection). Without it, detection-svc still runs --
# scans just skip the reverse-image-search leg. See
# apps/detection-svc/README.md "What this does not do".
GOOGLE_APPLICATION_CREDENTIALS=

DATABASE_URL=./data/api-gateway.db
PORT=4000
ASSET_SERVICE_URL=http://localhost:3002

JWT_ACCESS_SECRET=dev-insecure-access-secret-change-me
JWT_REFRESH_SECRET=dev-insecure-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

KMS_HOST=Philosophyz.iptime.org
KMS_PORT=8443
KMS_CA_CERT_PATH=./kms-keys/kms_ca.crt
KMS_PUBLIC_KEY_PATH=./kms-keys/teamA1_key_v1_pub.pem
KMS_ORG=teamA/teamA1
KMS_KEY_ID=key_v1

# Social login. Both providers are optional -- leave a pair unset and that
# provider's /auth/:provider route responds 501 instead of erroring.
# Get Google credentials from https://console.cloud.google.com (OAuth client,
# authorized redirect URI: {PUBLIC_URL}/auth/google/callback).
# Get Kakao credentials from https://developers.kakao.com (redirect URI:
# {PUBLIC_URL}/auth/kakao/callback; the "account_email" consent item must be
# enabled or the callback fails with "no email returned").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# PUBLIC_URL is this service's own externally-reachable base URL (used to
# build the OAuth redirect_uri sent to Google/Kakao). WEB_URL is where the
# frontend lives -- the OAuth callback redirects here with tokens in the
# URL hash after a successful login.
PUBLIC_URL=http://localhost:4000
WEB_URL=http://localhost:5173

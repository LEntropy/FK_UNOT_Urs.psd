DATABASE_URL=./data/asset-service.db
PROTECTION_SVC_URL=http://localhost:8000
BLOCKCHAIN_SVC_URL=http://localhost:3001
PORT=3002
CHAIN_NAME=polygon-amoy
REGISTRY_ADDRESS=0x12fe026abacd896956ccf71044640af04c7e8a97

# Envelope encryption at rest (src/crypto/imageEncryption.ts). Only
# KMS_PUBLIC_KEY_PATH is needed to accept uploads (wrapKey is client-side,
# no live KMS server call) -- the rest are only used when a background job
# actually decrypts an image for protection-svc to process.
KMS_PUBLIC_KEY_PATH=./kms-keys/teamA1_key_v1_pub.pem
KMS_HOST=127.0.0.1
KMS_PORT=8443
KMS_CA_CERT_PATH=./kms-keys/kms_ca.crt
KMS_ORG=teamA/teamA1
KMS_KEY_ID=key_v1

DATABASE_URL=./data/asset-service.db
PROTECTION_SVC_URL=http://localhost:8000
BLOCKCHAIN_SVC_URL=http://localhost:3001
PORT=3002
CHAIN_NAME=polygon-amoy
REGISTRY_ADDRESS=0x12fe026abacd896956ccf71044640af04c7e8a97

# Envelope encryption at rest (src/crypto/imageEncryption.ts). Only
# KMS_PUBLIC_KEY_PATH is needed to accept uploads (wrapKey is client-side,
# no live KMS server call) -- the rest are only used when a background job
# actually decrypts an image for protection-svc to process.
KMS_PUBLIC_KEY_PATH=./kms-keys/teamA1_key_v1_pub.pem
KMS_HOST=127.0.0.1
KMS_PORT=8443
KMS_CA_CERT_PATH=./kms-keys/kms_ca.crt
KMS_ORG=teamA/teamA1
KMS_KEY_ID=key_v1
# Scratch file for decryptToTempFile() -- deliberately a ./data-relative
# path, NOT the OS temp dir. If ./data lives on a different (larger) volume
# than the OS root filesystem, os.tmpdir() would silently write to the
# wrong disk and can fail with ENOSPC even with plenty of real free space
# available under ./data.
DECRYPT_TEMP_DIR=./data/tmp

# Object storage for the encrypted original (src/storage/objectStorage.ts).
# "local" (default) needs nothing else set -- preserves the existing
# ./data/encrypted local-dev behavior exactly. "s3" talks to any
# S3-compatible endpoint (MinIO locally via `docker compose --profile
# storage up minio`, real S3/R2/etc. in a real deployment).
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./data/encrypted
# S3_ENDPOINT=localhost
# S3_PORT=9000
# S3_USE_SSL=false
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=dontai-encrypted-originals
# S3_REGION=us-east-1

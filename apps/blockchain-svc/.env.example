# Polygon Amoy testnet RPC (same value as contracts/.env AMOY_RPC_URL)
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# Relayer wallet private key. Must be authorized on-chain via
# OwnershipRegistry.setRelayer(address, true) before registerFor() will work.
RELAYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Deployed OwnershipRegistry address (see contracts/DEPLOYMENTS.md)
REGISTRY_ADDRESS=0x12fe026abacd896956ccf71044640af04c7e8a97

PORT=3001

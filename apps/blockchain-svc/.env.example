# Polygon Amoy testnet RPC (same value as contracts/.env AMOY_RPC_URL)
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# Relayer wallet private key. Must be authorized on-chain via
# OwnershipRegistry.setRelayer(address, true) before registerFor() will work.
#
# Two ways to provide it (src/contract.ts, exactly one required):
#   1. Plaintext here (local dev / tests -- test/anvil.ts always uses this).
#   2. KMS-wrapped: set RELAYER_ENCRYPTED_KEY (base64 RSA-PKCS1 ciphertext,
#      produced with infra/kms-adapter's wrapKey()) + KMS_HOST/KMS_PORT/
#      KMS_CA_CERT_PATH/KMS_ORG/KMS_KEY_ID instead, and leave this unset.
#      contract.ts calls unwrapKey() against the live KMS server once at
#      startup -- the plaintext key then never sits in a deployed .env file.
RELAYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
# RELAYER_ENCRYPTED_KEY=
# KMS_HOST=Philosophyz.iptime.org
# KMS_PORT=8443
# KMS_CA_CERT_PATH=./kms-keys/kms_ca.crt
# KMS_ORG=teamA/teamA1
# KMS_KEY_ID=key_v1

# Deployed OwnershipRegistry address (see contracts/DEPLOYMENTS.md)
REGISTRY_ADDRESS=0x12fe026abacd896956ccf71044640af04c7e8a97

PORT=3001

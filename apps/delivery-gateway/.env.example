PORT=4500
ASSET_SERVICE_URL=http://localhost:3002

# HMAC key for signed render URLs (PROJECT_DESIGN.md §3-5) -- generate a
# real random one for anything beyond local dev:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
DELIVERY_SIGNING_SECRET=dev-insecure-signing-secret-change-me

# Seconds a signed URL stays valid before /asset/:id/render rejects it.
SIGN_TTL_SECONDS=300

# Comma-separated hostnames allowed in the Referer header (hotlink
# protection). Empty = no referer enforcement at all. A request with NO
# Referer header is always allowed regardless of this setting -- direct
# navigation and privacy-respecting browsers routinely strip it.
ALLOWED_REFERER_HOSTS=

# Per-IP sliding-window rate limit on /asset/:id/render.
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# PHASE4_SCOPING.md's adaptive-anti-scrape recommendation: how many
# *distinct* artworks one IP can request within the window before it's
# treated as enumeration (a real browsing session touches a handful; a
# scraper touches many quickly, regardless of whether artwork IDs are
# sequential -- see src/enumeration.rs's module doc).
ENUMERATION_MAX_DISTINCT_ARTWORKS=30
ENUMERATION_WINDOW_SECONDS=60

# PHASE4_SCOPING.md §2 honeypot URLs/assets. Comma-separated tokens for
# /decoy/:token -- never linked from any real page, seeded only into
# robots.txt's Disallow list, so a hit is high-confidence-bad-actor by
# construction (see src/honeypot.rs's module doc). Leave unset and one
# random token is generated at startup instead -- honeypots work with zero
# configuration, and the token doesn't need to stay stable across restarts.
HONEYPOT_TOKENS=

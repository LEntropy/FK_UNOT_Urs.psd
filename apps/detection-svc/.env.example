ASSET_SERVICE_URL=http://localhost:3002
PORT=8003

# Path to rust-core's release binary (see apps/protection-svc/orchestrate.py
# for the same pattern). Falls back to protection-svc's own build if unset.
RUST_CORE_BIN=../protection-svc/rust-core/target/release/rust-core

# Optional. Without this, /scan falls back to pHash + watermark detection
# only -- reverse-image web search is skipped (documented gap, not a hard
# failure). See README.md "What this does not do".
GOOGLE_APPLICATION_CREDENTIALS=

# Hamming-distance threshold (0-256, 0=identical) below which a candidate
# counts as a likely match. Calibrated against the numbers already measured
# in ml-engine/README.md: same-image round trips land at 0, this project's
# own L3_ANTI_TRAIN cloak output at 6, unrelated images at 138-142.
PHASH_MATCH_THRESHOLD=20

# Watermark payload rust-core embeds today (protection-svc/server.py's own
# default -- see README.md's "known gap" note on why this isn't yet
# per-artwork).
DEFAULT_WATERMARK_HEX=deadbeefcafef00d

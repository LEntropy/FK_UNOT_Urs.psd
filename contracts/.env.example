# Polygon Amoy testnet RPC (e.g. Alchemy, Infura)
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# Polygon mainnet RPC (for later, not used yet)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Deployer / relayer private key (testnet only — never commit a real key)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# For contract verification on Polygonscan
POLYGONSCAN_API_KEY=YOUR_API_KEY
